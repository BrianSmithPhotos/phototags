   "source": [
    "import exiftool\n",
    "\n",
    "files = [\"a.jpg\", \"b.raf\", \"c.tif\", \"d.orf\", \"e.dng\"]\n",
    "with exiftool.ExifTool() as et:\n",
    "    metadata = et.get_metadata_batch(files)\n",
    "for d in metadata:\n",
    "    print(\"{:20.20} {:20.20}\".format(d[\"SourceFile\"],\n",
    "                                     d[\"EXIF:DateTimeOriginal\"]))"
   ]
  }
 ],
